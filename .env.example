HF_TOKEN=your_huggingface_api_key_if_need_download_llm_models
DATABASE_URL=postgresql://ranything:ranything@localhost:5432/ranything
DATA_DIR=./data
HOST=127.0.0.1
# Default standalone port. Override if something else already uses 8000.
PORT=8000
# Next.js UI port (docker compose web service)
WEB_PORT=3000

# Auth (Studio UI)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=14
AUTH_REQUIRED=true

# Optional: lock /api/external/* for service clients (Bearer token).
# Leave empty for open local demo.
EXTERNAL_API_TOKEN=
# Alias also accepted: RANYTHING_API_TOKEN=

# LLM — Gemini (multi-key) or OpenAI-compatible / Ollama / vLLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_KEYS=
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3.2
# OLLAMA_MODEL=llama3.2

ENABLE_GRAPH_RAG=false
UI_LANGUAGE=en
